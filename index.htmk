<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Web3 Multi-Chain Wallet</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { background-color: #0f172a; color: white; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
        .glass-card { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.1); }
        .tab-active { color: #3b82f6; border-bottom: 2px solid #3b82f6; }
        .hide-scrollbar::-webkit-scrollbar { display: none; }
    </style>
</head>
<body class="max-w-md mx-auto min-h-screen flex flex-col p-4 pb-20">

    <header class="flex justify-between items-center mb-6">
        <div class="flex items-center space-x-2 bg-slate-800 px-3 py-1.5 rounded-full border border-slate-700">
            <div class="w-2 h-2 bg-green-500 rounded-full"></div>
            <select id="network-select" class="bg-transparent text-sm font-medium outline-none cursor-pointer">
                <option value="x-layer">X Layer</option>
                <option value="bnb">BNB Chain</option>
                <option value="solana">Solana</option>
            </select>
        </div>
        <i class="fa-solid fa-qrcode text-xl text-slate-400"></i>
    </header>

    <section class="text-center mb-8">
        <p class="text-slate-400 text-sm mb-1">总资产 (USD)</p>
        <h1 class="text-4xl font-bold tracking-tight">$12,450.88</h1>
        <p class="text-green-400 text-sm mt-1">+2.45% (24h)</p>
    </section>

    <nav class="grid grid-cols-4 gap-4 mb-8">
        <div class="flex flex-col items-center space-y-2 cursor-pointer">
            <div class="w-12 h-12 glass-card rounded-2xl flex items-center justify-center text-blue-400 text-xl hover:bg-slate-700">
                <i class="fa-solid fa-arrow-down"></i>
            </div>
            <span class="text-xs">充币</span>
        </div>
        <div class="flex flex-col items-center space-y-2 cursor-pointer">
            <div class="w-12 h-12 glass-card rounded-2xl flex items-center justify-center text-blue-400 text-xl hover:bg-slate-700">
                <i class="fa-solid fa-arrow-up"></i>
            </div>
            <span class="text-xs">提币</span>
        </div>
        <div class="flex flex-col items-center space-y-2 cursor-pointer">
            <div class="w-12 h-12 glass-card rounded-2xl flex items-center justify-center text-blue-400 text-xl hover:bg-slate-700">
                <i class="fa-solid fa-repeat"></i>
            </div>
            <span class="text-xs">交易</span>
        </div>
        <div class="flex flex-col items-center space-y-2 cursor-pointer">
            <div class="w-12 h-12 glass-card rounded-2xl flex items-center justify-center text-blue-400 text-xl hover:bg-slate-700">
                <i class="fa-solid fa-layer-group"></i>
            </div>
            <span class="text-xs">应用</span>
        </div>
    </nav>

    <section class="mb-6">
        <div class="flex space-x-6 border-b border-slate-800 mb-4">
            <button onclick="switchTab('tokens')" id="tab-tokens" class="pb-2 text-lg font-medium tab-active transition-all">代币列表</button>
            <button onclick="switchTab('defi')" id="tab-defi" class="pb-2 text-lg font-medium text-slate-500 hover:text-white transition-all">DeFi</button>
        </div>

        <div id="content-tokens" class="space-y-4">
            <div class="flex justify-between items-center p-2">
                <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center font-bold">X</div>
                    <div>
                        <p class="font-bold" id="native-name">OKB</p>
                        <p class="text-xs text-slate-500">X Layer Network</p>
                    </div>
                </div>
                <div class="text-right">
                    <p class="font-bold">120.50</p>
                    <p class="text-xs text-slate-500">$5,240.20</p>
                </div>
            </div>
            <div class="flex justify-between items-center p-2">
                <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 bg-green-500 rounded-full flex items-center justify-center font-bold italic">T</div>
                    <div>
                        <p class="font-bold">USDT</p>
                        <p class="text-xs text-slate-500">Tether USD</p>
                    </div>
                </div>
                <div class="text-right">
                    <p class="font-bold">7,210.68</p>
                    <p class="text-xs text-slate-500">$7,210.68</p>
                </div>
            </div>
            
            <button class="w-full py-3 mt-2 text-sm text-slate-400 border border-dashed border-slate-700 rounded-xl hover:bg-slate-800 transition-all">
                <i class="fa-solid fa-plus mr-2"></i>币种管理
            </button>
        </div>

        <div id="content-defi" class="hidden py-8 text-center text-slate-500">
            <i class="fa-solid fa-vault text-4xl mb-3 block"></i>
            <p>暂无活跃的 DeFi 协议</p>
            <button class="mt-4 text-blue-400 text-sm">去探索应用 <i class="fa-solid fa-chevron-right text-xs"></i></button>
        </div>
    </section>

    <section class="mb-6">
        <h3 class="text-sm font-semibold text-slate-400 mb-3 uppercase tracking-wider">市场行情 (USDT 对)</h3>
        <div class="flex space-x-3 overflow-x-auto hide-scrollbar">
            <div class="min-w-[120px] p-3 glass-card rounded-xl">
                <p class="text-xs text-slate-400 mb-1">BTC/USDT</p>
                <p class="font-bold">$64,231</p>
                <p class="text-xs text-green-400">+1.2%</p>
            </div>
            <div class="min-w-[120px] p-3 glass-card rounded-xl">
                <p class="text-xs text-slate-400 mb-1">ETH/USDT</p>
                <p class="font-bold">$3,452</p>
                <p class="text-xs text-red-400">-0.5%</p>
            </div>
            <div class="min-w-[120px] p-3 glass-card rounded-xl">
                <p class="text-xs text-slate-400 mb-1">SOL/USDT</p>
                <p class="font-bold">$145.20</p>
                <p class="text-xs text-green-400">+5.8%</p>
            </div>
        </div>
    </section>

    <section class="mt-auto">
        <div class="bg-blue-900/30 border border-blue-800/50 p-3 rounded-xl flex items-start space-x-3">
            <i class="fa-solid fa-bullhorn text-blue-400 mt-1"></i>
            <div>
                <p class="text-xs font-bold text-blue-300">系统公告</p>
                <p class="text-xs text-blue-200/70 leading-relaxed">X Layer 链主网升级已完成，所有功能现已恢复正常使用。</p>
            </div>
        </div>
    </section>

    <script>
        // 简单的选项卡切换逻辑
        function switchTab(tab) {
            const tokenTab = document.getElementById('tab-tokens');
            const defiTab = document.getElementById('tab-defi');
            const tokenContent = document.getElementById('content-tokens');
            const defiContent = document.getElementById('content-defi');

            if (tab === 'tokens') {
                tokenTab.classList.add('tab-active');
                tokenTab.classList.remove('text-slate-500');
                defiTab.classList.remove('tab-active');
                defiTab.classList.add('text-slate-500');
                tokenContent.classList.remove('hidden');
                defiContent.classList.add('hidden');
            } else {
                defiTab.classList.add('tab-active');
                defiTab.classList.remove('text-slate-500');
                tokenTab.classList.remove('tab-active');
                tokenTab.classList.add('text-slate-500');
                defiContent.classList.remove('hidden');
                tokenContent.classList.add('hidden');
            }
        }

        // 监听网络切换以模拟原生币更改
        document.getElementById('network-select').addEventListener('change', (e) => {
            const nativeName = document.getElementById('native-name');
            const val = e.target.value;
            if(val === 'x-layer') nativeName.innerText = 'OKB';
            else if(val === 'bnb') nativeName.innerText = 'BNB';
            else if(val === 'solana') nativeName.innerText = 'SOL';
        });
    </script>
</body>
</html>
